"@
[System.IO.File]::WriteAllText($htmlPath,$html,(New-Object System.Text.UTF8Encoding($false)))
$urlPath = 'file:///' + ($htmlPath -replace '\\','/')
$tmpPdf="$env:TEMP\soc-noskill-render-$dateStr-$($now.ToString('HHmmss')).pdf"
